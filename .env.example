# =========================
# Shared settings
# =========================
GO_ENV=development
AUTH_SECRET=change_me_to_a_secure_random_value

# Frontend -> backend URLs
# Used by Next.js server routes inside the frontend container.
BACKEND_URL=http://backend:8080
# Public URL exposed to browser/runtime where needed.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# =========================
# Backend database/admin
# =========================
MONGO_URI=mongodb://mongo:27017
DB_NAME=records_db
ADMIN_USER=admin
ADMIN_PASS=admin123

# =========================
# OIDC (Krufame Auth)
# =========================
OIDC_BASE_URL=https://auth.krufame.work
# Optional explicit discovery endpoint; leave empty to use base URL discovery.
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret

# =========================
# Public URLs for redirects/links
# =========================
FRONTEND_URL=http://localhost:3002
BACKEND_PUBLIC_URL=http://localhost:8080
# Optional override for sign/form link base URL; empty = infer from request headers.
SIGN_PUBLIC_BASE_URL=

# =========================
# Email notifications
# =========================
GMAIL_SERVICE_ACCOUNT_JSON=change_me_gmail_service_account_json
GMAIL_DELEGATE_EMAIL=delegate@example.com
NOTIFY_TO=notify@example.com

# =========================
# Form-link signing secret
# =========================
FORM_LINK_SECRET=change_me_to_a_strong_random_value
# Legacy fallback (optional, only used when FORM_LINK_SECRET is empty):
# JWT_SECRET=
