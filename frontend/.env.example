# Example frontend environment variables
# Copy to .env.local and customize. Do NOT commit real secrets.

AUTH_SECRET=replace-with-a-strong-random-string
BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# OIDC Configuration (Krufame Auth)
OIDC_BASE_URL=https://auth.krufame.work
OIDC_DISCOVERY_URL=https://auth.krufame.work/.well-known/openid-configuration
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
